[ext_resource type="Script" path="res://scripts/objects/cartridge_slot.gd" id="1_slot"]

; Slot collision — same local axes as the cart it holds (R_x(-90°) is applied
; at instance time in room.tscn). The slot must stick OUT further than the
; cart colliders in adjacent slots, so rays can reach an empty slot between
; two occupied ones. Height shrunk to avoid overlap between stacked slots.
; X = cart width span, Y = cart length (depth out of tower), Z = cart thickness.
