; ── Screen — deep dark hood recess with tilted CRT ────────────────────────────
; Hood protrudes 0.05 m forward from body front face (body front = +0.22 local Z)

[node name="ScreenHood" type="MeshInstance3D" parent="TerminalBody"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.06, 0.04, 0.30)
mesh = SubResource("Mesh_hood")
surface_material_override/0 = SubResource("Mat_hood")

; Screen node: 24° X tilt (top toward player). Z must clear the hood front face
; AFTER tilt — the quad's bottom sits at screen_z - 0.407*(h/2). For h=0.36 that's
; screen_z - 0.073. Hood front face at Z=0.35, so screen_z ≥ 0.43 keeps the bottom
; (and the DisplayZone collider) out of the hood box.
[node name="Screen" type="Node3D" parent="TerminalBody"]
transform = Transform3D(1, 0, 0, 0, 0.914, 0.407, 0, -0.407, 0.914, -0.06, 0.042, 0.44)

; SubViewport first so the ViewportTexture's NodePath can resolve at load-time.
[node name="SubViewport" type="SubViewport" parent="TerminalBody/Screen"]
size = Vector2i(480, 640)
render_target_clear_mode = 0
render_target_update_mode = 4
transparent_bg = false
disable_3d = true
handle_input_locally = true

[node name="ScreenSurface" type="MeshInstance3D" parent="TerminalBody/Screen"]
mesh = SubResource("Mesh_screen")

[node name="MicroficheUI" parent="TerminalBody/Screen/SubViewport" instance=ExtResource("2_microfiche_ui")]
