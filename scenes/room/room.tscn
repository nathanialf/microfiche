; ── Furniture — semicircle desk wrapping the player ──────────────────────────
; Desk centered on the player (X=0, Z=-0.55). Inner radius 0.58, outer 1.12.
; Top at Y=0.81. Built as an ArrayMesh by desk_ring.gd at runtime.

[node name="Furniture" type="Node3D" parent="."]

[node name="DeskRing" parent="Furniture" instance=ExtResource("7_desk_ring")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.98, -0.55)

; ── Objects on the desk arc ──────────────────────────────────────────────────
; Arc angle α: 0° = forward, + = player's right, - = player's left.
; Position at α, radius R: (R*sin(α), Y, -0.55 - R*cos(α)).
; Yaw to face player (screen/front at +Z local): yaw = -α.
; Holder yaw (open face at -Z local): yaw = 180° - α.

[node name="Objects" type="Node3D" parent="."]

; Microfiche at α=0°, radial 0.88 → position (0, 1.20, -1.43). Yaw = 0 (identity).
[node name="MicroficheReader" parent="Objects" instance=ExtResource("2_reader")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.0, 1.20, -1.43)

; ── Cartridge tower at α=+45°, radial 0.85 ───────────────────────────────────
; World position: (0.601, 0.98, -1.151). Yaw = 180° - 45° = 135°.
; Carts inside use R_x(-90°) so arched top → holder local -Z (open face / player).
;
; Holder local frame (before yaw):
;   X: side-to-side (142mm outer)
;   Y: up (shell bottom at 0 = desk surface; top of shell at +0.10)
;   Z: depth — open at -Z (where arched tops stick out toward player)
;
; Carts centered at X=0, Z=0 (depth-wise), Y = 0.015 / 0.045 / 0.075 stacked.

[node name="CartridgeTower" type="Node3D" parent="Objects"]
; Right arc, pulled closer + swung toward centre so the outer columns stay
; inside the player's reach. r≈1.00, θ≈40° → (0.643, -0.766).
; Orientation resolved at runtime by face_player.gd (local -Z at player).
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.643, 0.98, -0.766)
script = ExtResource("9_face_player")

